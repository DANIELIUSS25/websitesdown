# Required: Neon Postgres connection string
DATABASE_URL=postgres://user:pass@host/dbname
# Or use Netlify's managed variable:
# NETLIFY_DATABASE_URL=

# Required for cron endpoints (baseline + snapshot)
CRON_SECRET=your-random-secret-here

# Optional: Perplexity AI key for web intelligence feature
PERPLEXITY_API_KEY=

# Optional: Salt for anonymizing report fingerprints (set a unique value in production)
FINGERPRINT_SALT=

# Optional: Site URL override
NEXT_PUBLIC_SITE_URL=https://websitedown.com

# Required for auth (generate a random 64-char string)
JWT_SECRET=your-jwt-secret-here

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PRO_PLUS=price_xxx

# Alert channels
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
